{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
	  "type": "auto",
	  "source": "~/.dotfiles/.config/fastfetch/logo/*.txt",
	  "width": 20,
      "preserveAspectRatio":true,
      "padding": {
          "top":0,
          "right": 5
      }
  	
  },





  "modules": [
    "title",
    "separator",
    "os",
    "kernel",
    "uptime",
    "packages",
    "shell",
    "display",
    "wm",
    "terminal",
    "cpu",
    "gpu",
    "swap",
    "disk",
    "localip",
    "battery",
    "poweradapter",
    "locale",
    "break",
    "colors"
  ]
}
